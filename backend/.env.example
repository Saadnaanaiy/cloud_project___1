# ─── Environment ──────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_NAME=employee_db

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRES_IN=7d

# ─── SMTP (Mailtrap / any SMTP provider) ──────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@example.com

# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
